# ────────────────────────────────────────────────
# MoveIQ 환경변수 템플릿
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요.
# .env.local 은 절대 Git에 커밋하지 마세요.
# ────────────────────────────────────────────────

# ── 🔴 SECRET (절대 노출 금지) ──────────────────
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
TOSS_PAYMENTS_SECRET_KEY=test_sk_...
TOSS_WEBHOOK_SECRET=your_toss_webhook_secret

# ── 🟡 SERVER-ONLY (서버에서만 사용) ────────────
CLAUDE_API_KEY=sk-ant-...
# Claude API 월 사용량 한도는 Anthropic Console에서 직접 설정할 것

# ── 🟢 PUBLIC (프론트 노출 허용) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_key
# Kakao Developers → 앱 설정 → 플랫폼 → Web → 도메인 제한 필수

# ── 사이트 URL (배포 후 실제 주소로 변경) ────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
