# ────────────────────────────────────────────────
# MoveIQ 환경변수 템플릿
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요.
# .env.local 은 절대 Git에 커밋하지 마세요.
# ────────────────────────────────────────────────

# ── 🔴 SECRET (절대 노출 금지) ──────────────────
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
TOSS_PAYMENTS_SECRET_KEY=test_sk_...
TOSS_WEBHOOK_SECRET=your_toss_webhook_secret

# ── 🟡 SERVER-ONLY (서버에서만 사용) ────────────
CLAUDE_API_KEY=sk-ant-...
# Claude API 월 사용량 한도는 Anthropic Console에서 직접 설정할 것

# Naver Maps Geocoding + Place API (서버 전용 — 절대 NEXT_PUBLIC_ 붙이지 말 것)
# Naver Cloud Console → Application → 인증 정보에서 복사
# 선택 서비스: Dynamic Map + Geocoding 체크 필수
NAVER_MAP_CLIENT_ID=your_naver_client_id
NAVER_MAP_CLIENT_SECRET=your_naver_client_secret

# ── 공공데이터 API 키 ─────────────────────────────────────
# 브이월드 (디지털트윈국토) — 개발제한구역, 도시지역, 도시계획시설
# https://www.vworld.kr → 인증키 신청
VWORLD_API_KEY=B6D3D68A-B3B4-33EE-9207-CD291FE806A8

# 건설CALS — 공사중 시설물 현황
# https://www.calspia.go.kr
CALS_API_KEY=21A5332F-5DBC-4399-A14D-BB352D183954

# data.go.kr (국토교통부) — 건축인허가, 개발행위허가, 잠재력등급, 실거래가, 통행시간
# https://www.data.go.kr → 마이페이지 → 개발계정
PUBLIC_DATA_API_KEY=cbc1259d77bc315a99696b551a008b1d80780f92bc556c804ae6950b950a4fc8

# ── 🟢 PUBLIC (프론트 노출 허용) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Naver Maps 지도 표시용 (Client ID 만 사용 — Secret 절대 노출 금지)
NEXT_PUBLIC_NAVER_MAP_KEY=your_naver_client_id

# ── 사이트 URL (배포 후 실제 주소로 변경) ────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 어드민 이메일 — /admin 경로 접근 허용 계정 (1개)
ADMIN_EMAIL=your_admin_email@gmail.com
